xt","url":"/docs/sdk/introduction#partitioning-strategies","content":"Description"},"934":{"id":"/docs/sdk/introduction-95","page_id":"/docs/sdk/introduction","tags":[],"type":"text","url":"/docs/sdk/introduction#partitioning-strategies","content":"partition_id(n)"},"935":{"id":"/docs/sdk/introduction-96","page_id":"/docs/sdk/introduction","tags":[],"type":"text","url":"/docs/sdk/introduction#partitioning-strategies","content":"Send to a specific partition"},"936":{"id":"/docs/sdk/introduction-97","page_id":"/docs/sdk/introduction","tags":[],"type":"text","url":"/docs/sdk/introduction#partitioning-strategies","content":"balanced()"},"937":{"id":"/docs/sdk/introduction-98","page_id":"/docs/sdk/introduction","tags":[],"type":"text","url":"/docs/sdk/introduction#partitioning-strategies","content":"Round-robin across partitions"},"938":{"id":"/docs/sdk/introduction-99","page_id":"/docs/sdk/introduction","tags":[],"type":"text","url":"/docs/sdk/introduction#partitioning-strategies","content":"messages_key(key)"},"939":{"id":"/docs/sdk/introduction-100","page_id":"/docs/sdk/introduction","tags":[],"type":"text","url":"/docs/sdk/introduction#partitioning-strategies","content":"Hash-based routing by key"},"940":{"id":"/docs/web_ui/start","page_id":"/docs/web_ui/start","type":"page","content":"Iggy Web UI","breadcrumbs":["Documentation","Web UI"],"tags":[],"url":"/docs/web_ui/start"},"941":{"id":"/docs/web_ui/start-0","page_id":"/docs/web_ui/start","type":"heading","tags":[],"url":"/docs/web_ui/start#running-modes","content":"Running modes"},"942":{"id":"/docs/web_ui/start-1","page_id":"/docs/web_ui/start","type":"heading","tags":[],"url":"/docs/web_ui/start#embedded-mode","content":"Embedded mode"},"943":{"id":"/docs/web_ui/start-2","page_id":"/docs/web_ui/start","type":"heading","tags":[],"url":"/docs/web_ui/start#standalone-mode","content":"Standalone mode"},"944":{"id":"/docs/web_ui/start-3","page_id":"/docs/web_ui/start","type":"heading","tags":[],"url":"/docs/web_ui/start#features","content":"Features"},"945":{"id":"/docs/web_ui/start-4","page_id":"/docs/web_ui/start","type":"heading","tags":[],"url":"/docs/web_ui/start#docker-compose-example","content":"Docker Compose example"},"946":{"id":"/docs/web_ui/start-5","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start","content":"Iggy Web UI provides a comprehensive dashboard for Iggy server. It allows you to monitor the server's health, streams, topics, browse the messages, users and more. The dashboard is built with SvelteKit and TypeScript and is available as open-source as well as the Docker image on Docker Hub."},"947":{"id":"/docs/web_ui/start-6","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#embedded-mode","content":"The Web UI can be compiled directly into the Iggy server binary using the iggy-web feature flag. When enabled, it is served at the /ui endpoint:"},"948":{"id":"/docs/web_ui/start-7","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#embedded-mode","content":"This mode requires the server to be built with the iggy-web feature. If the server is compiled without it and web_ui = true, a warning is logged but the server continues to run normally."},"949":{"id":"/docs/web_ui/start-8","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#standalone-mode","content":"Run the Web UI as a separate container:"},"950":{"id":"/docs/web_ui/start-9","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"The Web UI provides the following pages and functionality:"},"951":{"id":"/docs/web_ui/start-10","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Dashboard - server health overview and key metrics"},"952":{"id":"/docs/web_ui/start-11","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Streams - list, create, and manage streams"},"953":{"id":"/docs/web_ui/start-12","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Topics - manage topics per stream (create, update, delete, purge)"},"954":{"id":"/docs/web_ui/start-13","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Partitions - view partition details per topic"},"955":{"id":"/docs/web_ui/start-14","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Messages - browse messages per partition with built-in decoders:"},"956":{"id":"/docs/web_ui/start-15","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"JSON decoder (formatted JSON output)"},"957":{"id":"/docs/web_ui/start-16","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"String decoder (UTF-8 text)"},"958":{"id":"/docs/web_ui/start-17","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"XML decoder"},"959":{"id":"/docs/web_ui/start-18","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Clients - list connected clients and their sessions"},"960":{"id":"/docs/web_ui/start-19","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Logs - real-time server log viewer"},"961":{"id":"/docs/web_ui/start-20","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Users - user management (create, update, delete, permissions)"},"962":{"id":"/docs/web_ui/start-21","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#features","content":"Settings - server configuration overview, terminal access, and Web UI preferences"},"963":{"id":"/docs/web_ui/start-22","page_id":"/docs/web_ui/start","tags":[],"type":"text","url":"/docs/web_ui/start#docker-compose-example","content":"Here's the full example of the docker-compose.yml file that starts the Iggy server, initializes it with the my-stream stream and my-topic topic with the help of Iggy CLI, and starts the Iggy Web UI:"},"964":{"id":"/docs/server/benchmarking","page_id":"/docs/server/benchmarking","type":"page","content":"Benchmarking","breadcrumbs":["Documentation","Server"],"tags":[],"url":"/docs/server/benchmarking"},"965":{"id":"/docs/server/benchmarking-0","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Benchmarks should be the first-class citizens. We believe that performance is crucial for any system, and we strive to provide the best possible performance for our users. Please check, why we believe that the transparent benchmarking is so important."},"966":{"id":"/docs/server/benchmarking-1","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"We've also built the benchmarking platform where anyone can upload the benchmarks and compare the results with others. This is the another open-source project available here."},"967":{"id":"/docs/server/benchmarking-2","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Iggy comes with a built-in benchmarking tool iggy-bench that allows you to measure the performance of the server. It is written in Rust and uses the tokio runtime for asynchronous I/O operations mimicking the example client applications.  The tool is designed to be as close to real-world scenarios as possible, so you can use it to estimate the performance of the server in your environment. It is part of the core repository and can be found in the bench directory."},"968":{"id":"/docs/server/benchmarking-3","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"To benchmark the project, first build the project in release mode:"},"969":{"id":"/docs/server/benchmarking-4","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Then, run the benchmarking app with the desired options:"},"970":{"id":"/docs/server/benchmarking-5","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Sending (writing) benchmark"},"971":{"id":"/docs/server/benchmarking-6","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Polling (reading) benchmark"},"972":{"id":"/docs/server/benchmarking-7","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Parallel sending and polling benchmark"},"973":{"id":"/docs/server/benchmarking-8","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Balanced sending to multiple partitions benchmark"},"974":{"id":"/docs/server/benchmarking-9","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Consumer group polling benchmark:"},"975":{"id":"/docs/server/benchmarking-10","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Parallel balanced sending and polling from consumer group benchmark:"},"976":{"id":"/docs/server/benchmarking-11","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"End to end producing and consuming benchmark (single task produces and consumes messages in sequence):"},"977":{"id":"/docs/server/benchmarking-12","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"These benchmarks would start the server with the default configuration, create a stream, topic and partition, and then send or poll the messages. The default configuration is optimized for the best performance, so you might want to tweak it for your needs. If you need more options, please refer to iggy-bench subcommands help and examples."},"978":{"id":"/docs/server/benchmarking-13","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"For example, to run the benchmark for the already started server, provide the additional argument --server-address 0.0.0.0:8090."},"979":{"id":"/docs/server/benchmarking-14","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Depending on the hardware, transport protocol (quic, tcp or http) and payload size (messages-per-batch * message-size) you might expect over 5000 MB/s (e.g. 5M of 1 KB msg/sec) throughput for writes and reads."},"980":{"id":"/docs/server/benchmarking-15","page_id":"/docs/server/benchmarking","tags":[],"type":"text","url":"/docs/server/benchmarking","content":"Iggy is already capable of processing millions of messages per second at the microseconds range for p99+ latency, and with the upcoming optimizations related to the io_uring support along with the shared-nothing design, it will only get better."},"981":{"id":"/docs/server/configuration","page_id":"/docs/server/configuration","type":"page","content":"Configuration","breadcrumbs":["Documentation","Server"],"tags":[],"url":"/docs/server/configuration"},"982":{"id":"/docs/server/configuration-0","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#environment-variables","content":"Environment variables"},"983":{"id":"/docs/server/configuration-1","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#command-line-arguments","content":"Command-line arguments"},"984":{"id":"/docs/server/configuration-2","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#durability","content":"Durability"},"985":{"id":"/docs/server/configuration-3","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#sharding","content":"Sharding"},"986":{"id":"/docs/server/configuration-4","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#memory-pool","content":"Memory pool"},"987":{"id":"/docs/server/configuration-5","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#clustering","content":"Clustering"},"988":{"id":"/docs/server/configuration-6","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#http","content":"HTTP"},"989":{"id":"/docs/server/configuration-7","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#tcp","content":"TCP"},"990":{"id":"/docs/server/configuration-8","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#quic","content":"QUIC"},"991":{"id":"/docs/server/configuration-9","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#websocket","content":"WebSocket"},"992":{"id":"/docs/server/configuration-10","page_id":"/docs/server/configuration","type":"heading","tags":[],"url":"/docs/server/configuration#telemetry","content":"Telemetry"},"993":{"id":"/docs/server/configuration-11","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration","content":"The server reads its configuration from core/server/config.toml by default. You can specify a different path by setting the IGGY_CONFIG_PATH environment variable (e.g., export IGGY_CONFIG_PATH=/path/to/config.toml). You can also use a .env file to override specific settings using the IGGY_ prefix (e.g., IGGY_HTTP_ENABLED=true)."},"994":{"id":"/docs/server/configuration-12","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration","content":"If no configuration file is found, the server uses its built-in defaults."},"995":{"id":"/docs/server/configuration-13","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration","content":"Let's take a look at the available configuration options. The following example shows all settings with their default values:"},"996":{"id":"/docs/server/configuration-14","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration","content":"Note: For the most up-to-date configuration reference, please refer to the config.toml file in the project's repository."},"997":{"id":"/docs/server/configuration-15","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#environment-variables","content":"Every configuration option can be overridden using environment variables with the IGGY_ prefix. The naming convention follows the TOML structure with underscores:"},"998":{"id":"/docs/server/configuration-16","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"The server binary accepts the following arguments:"},"999":{"id":"/docs/server/configuration-17","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"Argument"},"1000":{"id":"/docs/server/configuration-18","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"Description"},"1001":{"id":"/docs/server/configuration-19","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"--config-provider file"},"1002":{"id":"/docs/server/configuration-20","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"Configuration source (default: file)"},"1003":{"id":"/docs/server/configuration-21","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"--fresh"},"1004":{"id":"/docs/server/configuration-22","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"Wipe data directory before start"},"1005":{"id":"/docs/server/configuration-23","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"--with-default-root-credentials"},"1006":{"id":"/docs/server/configuration-24","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"Set root to iggy/iggy (dev only)"},"1007":{"id":"/docs/server/configuration-25","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"--follower"},"1008":{"id":"/docs/server/configuration-26","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#command-line-arguments","content":"Advertise as follower node (clustering)"},"1009":{"id":"/docs/server/configuration-27","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#durability","content":"The single node Iggy server by default provides low durability guarantees, meaning that in case of a crash or power loss, some of messages might be lost.\nTo fix that you can enable enforce_fsync option in system.partition section together with setting messages_required_to_save and size_of_messages_required_to_save to lowest allowed values (minimum of 1 for count, and 512 B for size). In case if your message size is not big enough, you might want to pad your message to 512 B boundary, or alternatively send messages in batches."},"1010":{"id":"/docs/server/configuration-28","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#durability","content":"For even stronger durability, enable the message_saver with enforce_fsync = true which provides a background fsync at a configurable interval (default 30s)."},"1011":{"id":"/docs/server/configuration-29","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#sharding","content":"The [system.sharding] section controls how the server maps shards to CPU cores. This is key to the thread-per-core architecture:"},"1012":{"id":"/docs/server/configuration-30","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#sharding","content":"\"all\" - one shard per available CPU core"},"1013":{"id":"/docs/server/configuration-31","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#sharding","content":"A numeric value (e.g. 4) - exactly N shards"},"1014":{"id":"/docs/server/configuration-32","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#sharding","content":"A range (e.g. \"5..8\") - shards on cores 5, 6, 7"},"1015":{"id":"/docs/server/configuration-33","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#sharding","content":"\"numa:auto\" - automatic NUMA-aware allocation"},"1016":{"id":"/docs/server/configuration-34","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#sharding","content":"\"numa:nodes=0,1;cores=4;no_ht=true\" - fine-grained NUMA control"},"1017":{"id":"/docs/server/configuration-35","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#sharding","content":"See Architecture for more details on the thread-per-core design."},"1018":{"id":"/docs/server/configuration-36","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#memory-pool","content":"The [system.memory_pool] section configures the pre-allocated buffer pool used for zero-copy message passing:"},"1019":{"id":"/docs/server/configuration-37","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#memory-pool","content":"size - total pool size (minimum 512 MiB, must be page-aligned to 4096 bytes)"},"1020":{"id":"/docs/server/configuration-38","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#memory-pool","content":"bucket_capacity - buffers per bucket (must be power of 2, minimum 128)"},"1021":{"id":"/docs/server/configuration-39","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#memory-pool","content":"The pool has 32 buckets with buffer sizes from 256 B to 512 MiB"},"1022":{"id":"/docs/server/configuration-40","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#clustering","content":"The [cluster] section configures multi-node replication using Viewstamped Replication (VSR). See Clustering for details. When clustering is enabled, all nodes must share the same cluster name."},"1023":{"id":"/docs/server/configuration-41","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#http","content":"An optional transport layer, which can be used to connect to the server with any tool or application that supports HTTP. It is enabled by default, but you can disable it by setting enabled to false. The address option specifies the address and port to listen on. The cors section allows you to configure the CORS policy, which internally uses Tower middleware."},"1024":{"id":"/docs/server/configuration-42","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#http","content":"HTTP API is built on top of Axum and you can find all the available endpoints in server.http file, which can be used with REST Client extension for VS Code."},"1025":{"id":"/docs/server/configuration-43","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#http","content":"To consume the HTTP API from Iggy SDK, you need to make use of the available HttpClient component."},"1026":{"id":"/docs/server/configuration-44","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#http","content":"HTTP API is highly performant, however, it's not as performant as TCP, and, since it's a stateless protocol, there's no such thing as the ongoing connection between client and server, thus some of the features such as consumer groups are not available."},"1027":{"id":"/docs/server/configuration-45","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#http","content":"The HTTP server also hosts Prometheus metrics at /metrics (configurable) and the optional embedded Web UI at /ui (when compiled with iggy-web feature and web_ui = true)."},"1028":{"id":"/docs/server/configuration-46","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#tcp","content":"An optional transport layer, which can be used to connect to the server with any tool or application that supports TCP. It is enabled by default, but you can disable it by setting enabled to false. The address option specifies the address and port to listen on."},"1029":{"id":"/docs/server/configuration-47","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#tcp","content":"TCP provides the highest performance and throughput as it works directly with the binary data without an additional overhead of e.g. HTTP spec along with the JSON serialization."},"1030":{"id":"/docs/server/configuration-48","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#tcp","content":"When socket_migration is enabled (default), TCP sockets can be migrated between shards to avoid cross-shard forwarding of data plane operations."},"1031":{"id":"/docs/server/configuration-49","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#tcp","content":"To consume the TCP API from Iggy SDK, you need to make use of the available TcpClient component."},"1032":{"id":"/docs/server/configuration-50","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#quic","content":"An optional transport layer, which can be used to connect to the server with any tool or application that supports QUIC. It is enabled by default, but you can disable it by setting enabled to false. The address option specifies the address and port to listen on."},"1033":{"id":"/docs/server/configuration-51","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#quic","content":"Similar to TCP it's a stateful protocol, however, it's not as performant as TCP. QUIC support is built on top of Quinn library, and all the remaining options are essentially the direct mapping of the options available in Quinn. QUIC and TCP use the same custom binary protocol specification. QUIC has built-in mandatory TLS encryption."},"1034":{"id":"/docs/server/configuration-52","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#quic","content":"To consume the QUIC API from Iggy SDK, you need to make use of the available QuicClient component."},"1035":{"id":"/docs/server/configuration-53","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#websocket","content":"An optional transport layer, which can be used to connect to the server with any tool or application that supports WebSocket. It is enabled by default, but you can disable it by setting enabled to false. The address option specifies the address and port to listen on."},"1036":{"id":"/docs/server/configuration-54","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#websocket","content":"WebSocket uses a custom compio-ws implementation that bridges tungstenite with compio's completion-based I/O model. It runs on all shards and supports optional TLS."},"1037":{"id":"/docs/server/configuration-55","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#websocket","content":"To consume the WebSocket API from Iggy SDK, you need to make use of the available WebSocketClient component."},"1038":{"id":"/docs/server/configuration-56","page_id":"/docs/server/configuration","tags":[],"type":"text","url":"/docs/server/configuration#telemetry","content":"The [telemetry] section configures OpenTelemetry integration for logs and traces. Supports both gRPC and HTTP transports for sending data to your observability backend (e.g. Jaeger, Grafana Tempo, Loki)."},"1039":{"id":"/docs/server/docker","page_id":"/docs/server/docker","type":"page","content":"Docker & Helm","breadcrumbs":["Documentation","Server"],"tags":[],"url":"/docs/server/docker"},"1040":{"id":"/docs/server/docker-0","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#docker","content":"Docker"},"1041":{"id":"/docs/server/docker-1","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#why-these-capabilities","content":"Why these capabilities?"},"1042":{"id":"/docs/server/docker-2","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#available-images","content":"Available images"},"1043":{"id":"/docs/server/docker-3","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#building-from-source","content":"Building from source"},"1044":{"id":"/docs/server/docker-4","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#running-the-cli-inside-the-container","content":"Running the CLI inside the container"},"1045":{"id":"/docs/server/docker-5","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#helm-charts","content":"Helm charts"},"1046":{"id":"/docs/server/docker-6","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#quick-start","content":"Quick start"},"1047":{"id":"/docs/server/docker-7","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#chart-components","content":"Chart components"},"1048":{"id":"/docs/server/docker-8","page_id":"/docs/server/docker","type":"heading","tags":[],"url":"/docs/server/docker#key-values","content":"Key values"},"1049":{"id":"/docs/server/docker-9","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#docker","content":"You can easily run the Iggy server with Docker - the official images can be found here, simply type docker pull apache/iggy."},"1050":{"id":"/docs/server/docker-10","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#docker","content":"Below is an example of the docker-compose.yml file which additionally overrides the default configuration (described in the section below) with the environment variables. If you prefer using the configuration file, you can mount it as a volume and provide the path to it with the IGGY_CONFIG_PATH environment variable."},"1051":{"id":"/docs/server/docker-11","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#docker","content":"When running the container, make sure to include the additional capabilities required by io_uring and CPU affinity:"},"1052":{"id":"/docs/server/docker-12","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#docker","content":"Or when running with docker run:"},"1053":{"id":"/docs/server/docker-13","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#why-these-capabilities","content":"SYS_NICE - required for setting CPU affinity (sched_setaffinity) in the thread-per-core architecture"},"1054":{"id":"/docs/server/docker-14","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#why-these-capabilities","content":"seccomp:unconfined - required for io_uring syscalls which are blocked by Docker's default seccomp profile"},"1055":{"id":"/docs/server/docker-15","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#why-these-capabilities","content":"memlock: -1 - io_uring needs to lock memory pages shared between user space and kernel"},"1056":{"id":"/docs/server/docker-16","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"Image"},"1057":{"id":"/docs/server/docker-17","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"Description"},"1058":{"id":"/docs/server/docker-18","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"apache/iggy"},"1059":{"id":"/docs/server/docker-19","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"Server + CLI"},"1060":{"id":"/docs/server/docker-20","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"apache/iggy-web-ui"},"1061":{"id":"/docs/server/docker-21","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"Standalone Web UI"},"1062":{"id":"/docs/server/docker-22","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"apache/iggy-connect"},"1063":{"id":"/docs/server/docker-23","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"Connectors runtime"},"1064":{"id":"/docs/server/docker-24","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"apache/iggy-mcp"},"1065":{"id":"/docs/server/docker-25","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"MCP server"},"1066":{"id":"/docs/server/docker-26","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#available-images","content":"Images tagged latest are based on stable releases. Images tagged edge are built from the latest master branch."},"1067":{"id":"/docs/server/docker-27","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#building-from-source","content":"The Dockerfile uses a multi-stage build: Rust compilation (including the Web UI via npm), then a minimal Debian slim image. To build:"},"1068":{"id":"/docs/server/docker-28","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#building-from-source","content":"Or use docker compose up directly from the repository root."},"1069":{"id":"/docs/server/docker-29","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#helm-charts","content":"Helm charts for Kubernetes deployment are available in the repository."},"1070":{"id":"/docs/server/docker-30","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"The chart includes templates for:"},"1071":{"id":"/docs/server/docker-31","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"Deployment - the Iggy server pod with required security context (SYS_NICE, seccomp unconfined, unlimited memlock)"},"1072":{"id":"/docs/server/docker-32","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"Service - exposes TCP (8090), QUIC (8080), HTTP (3000), and WebSocket (8092) ports"},"1073":{"id":"/docs/server/docker-33","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"ServiceAccount - dedicated service account"},"1074":{"id":"/docs/server/docker-34","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"PersistentVolumeClaim - persistent storage for local_data"},"1075":{"id":"/docs/server/docker-35","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"HPA - Horizontal Pod Autoscaler (optional)"},"1076":{"id":"/docs/server/docker-36","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"Ingress - optional ingress for HTTP access"},"1077":{"id":"/docs/server/docker-37","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"ServiceMonitor - Prometheus ServiceMonitor for metrics collection (optional)"},"1078":{"id":"/docs/server/docker-38","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#chart-components","content":"Secret - root user credentials"},"1079":{"id":"/docs/server/docker-39","page_id":"/docs/server/docker","tags":[],"type":"text","url":"/docs/server/docker#key-values","content":"Customize the values file for your environment and deploy with:"},"1080":{"id":"/docs/server/introduction","page_id":"/docs/server/introduction","type":"page","content":"Introduction","breadcrumbs":["Documentation","Server"],"tags":[],"url":"/docs/server/introduction"},"1081":{"id":"/docs/server/introduction-0","page_id":"/docs/server/introduction","tags":[],"type":"text","url":"/docs/server/introduction","content":"Iggy server is the most important part of the system as it's responsible for handling all the incoming connections, managing the data and providing the API for the clients. The server is written in Rust and can be run on any platform that supports it."},"1082":{"id":"/docs/server/introduction-1","page_id":"/docs/server/introduction","tags":[],"type":"text","url":"/docs/server/introduction","content":"The releases are published to GitHub and can be found here. The official Docker images can be found here, simply type docker pull apache/iggy."},"1083":{"id":"/docs/server/introduction-2","page_id":"/docs/server/introduction","tags":[],"type":"text","url":"/docs/server/introduction","content":"Keep in mind, that if you were to compile the source code in release mode, the longer compilation time is due to LTO enabled in profile."},"1084":{"id":"/docs/server/introduction-3","page_id":"/docs/server/introduction","tags":[],"type":"text","url":"/docs/server/introduction","content":"The HTTP API endpoints can be found in server.http file, which can be used with REST Client extension for VS Code."},"1085":{"id":"/docs/server/introduction-4","page_id":"/docs/server/introduction","tags":[],"type":"text","url":"/docs/server/introduction","content":"In order to see the detailed logs from the server, run it with RUST_LOG=trace environment variable."},"1086":{"id":"/docs/server/introduction-5","page_id":"/docs/server/introduction","tags":[],"type":"text","url":"/docs/server/introduction","content":"And finally, to seed the example data, simply execute cargo r --bin data-seeder-tool from the root of the repository while running your Iggy server."},"1087":{"id":"/docs/server/introduction-6","page_id":"/docs/server/introduction","tags":[],"type":"text","url":"/docs/server/introduction","content":"All the requests to the server except of sending a ping, fetching the stats or logging in, require the session to be authenticated. The session is created by logging in with the user's credentials or personal access token and is valid for the duration of the session or until the user logs out or the connection is lost. In case of HTTP API, the authentication is done by providing the Authorization header with the Bearer token."},"1088":{"id":"/docs/server/networking","page_id":"/docs/server/networking","type":"page","content":"Networking","breadcrumbs":["Documentation","Server"],"tags":[],"url":"/docs/server/networking"},"1089":{"id":"/docs/server/networking-0","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#transport-protocols","content":"Transport protocols"},"1090":{"id":"/docs/server/networking-1","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#binary-protocol","content":"Binary protocol"},"1091":{"id":"/docs/server/networking-2","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#protocol-distribution-across-shards","content":"Protocol distribution across shards"},"1092":{"id":"/docs/server/networking-3","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#tcp","content":"TCP"},"1093":{"id":"/docs/server/networking-4","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#quic","content":"QUIC"},"1094":{"id":"/docs/server/networking-5","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#http","content":"HTTP"},"1095":{"id":"/docs/server/networking-6","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#websocket","content":"WebSocket"},"1096":{"id":"/docs/server/networking-7","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#tls","content":"TLS"},"1097":{"id":"/docs/server/networking-8","page_id":"/docs/server/networking","type":"heading","tags":[],"url":"/docs/server/networking#heartbeat","content":"Heartbeat"},"1098":{"id":"/docs/server/networking-9","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking","content":"Iggy supports four transport protocols simultaneously, each optimized for different use cases. All stateful protocols (TCP, QUIC, WebSocket) use the same custom binary wire protocol, while HTTP provides a standard REST API."},"1099":{"id":"/docs/server/networking-10","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Protocol"},"1100":{"id":"/docs/server/networking-11","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Default Address"},"1101":{"id":"/docs/server/networking-12","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Implementation"},"1102":{"id":"/docs/server/networking-13","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Best for"},"1103":{"id":"/docs/server/networking-14","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"TCP"},"1104":{"id":"/docs/server/networking-15","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"127.0.0.1:8090"},"1105":{"id":"/docs/server/networking-16","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"compio + custom binary framing"},"1106":{"id":"/docs/server/networking-17","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Highest throughput, lowest latency"},"1107":{"id":"/docs/server/networking-18","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"QUIC"},"1108":{"id":"/docs/server/networking-19","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"127.0.0.1:8080"},"1109":{"id":"/docs/server/networking-20","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"compio-quic (quinn)"},"1110":{"id":"/docs/server/networking-21","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Secure connections, multiplexing"},"1111":{"id":"/docs/server/networking-22","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"HTTP"},"1112":{"id":"/docs/server/networking-23","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"127.0.0.1:3000"},"1113":{"id":"/docs/server/networking-24","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"axum"},"1114":{"id":"/docs/server/networking-25","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"REST API, web integrations"},"1115":{"id":"/docs/server/networking-26","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"WebSocket"},"1116":{"id":"/docs/server/networking-27","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"127.0.0.1:8092"},"1117":{"id":"/docs/server/networking-28","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"compio-ws"},"1118":{"id":"/docs/server/networking-29","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Browser clients, bidirectional streaming"},"1119":{"id":"/docs/server/networking-30","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#transport-protocols","content":"Performance ranking (lowest to highest overhead): TCP > QUIC > WebSocket > HTTP"},"1120":{"id":"/docs/server/networking-31","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#binary-protocol","content":"TCP, QUIC, and WebSocket all use the same binary protocol format. Each request/response frame consists of:"},"1121":{"id":"/docs/server/networking-32","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#binary-protocol","content":"The iggy_binary_protocol crate provides zero-copy serialization for all protocol frames. Foreign SDKs implement this protocol natively."},"1122":{"id":"/docs/server/networking-33","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#protocol-distribution-across-shards","content":"The transport servers are distributed across shards based on their requirements:"},"1123":{"id":"/docs/server/networking-34","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#protocol-distribution-across-shards","content":"Shard 0: HTTP server (axum) and QUIC server"},"1124":{"id":"/docs/server/networking-35","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#protocol-distribution-across-shards","content":"All shards: TCP and WebSocket servers"},"1125":{"id":"/docs/server/networking-36","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#protocol-distribution-across-shards","content":"This distribution means TCP and WebSocket connections can be served by any shard, which works well with TCP socket migration."},"1126":{"id":"/docs/server/networking-37","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tcp","content":"TCP provides the highest performance as it works directly with binary data without the overhead of HTTP or TLS handshakes (unless TLS is enabled). Key features:"},"1127":{"id":"/docs/server/networking-38","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tcp","content":"Socket migration: when enabled (default), TCP sockets can be migrated between shards. If a client's request targets a partition owned by a different shard, the socket moves to the owning shard instead of forwarding the request, eliminating cross-shard hops on the data path."},"1128":{"id":"/docs/server/networking-39","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tcp","content":"IPv6 support: configurable via ipv6 = true"},"1129":{"id":"/docs/server/networking-40","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tcp","content":"Socket tuning: configurable buffer sizes, keepalive, nodelay (Nagle algorithm), and linger timeout"},"1130":{"id":"/docs/server/networking-41","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#quic","content":"QUIC provides built-in TLS encryption and stream multiplexing. It uses the same binary protocol as TCP but runs over UDP. QUIC support is built on top of the quinn library. While not quite as fast as TCP, QUIC provides better security out of the box (TLS is mandatory)."},"1131":{"id":"/docs/server/networking-42","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#http","content":"The HTTP API is built on axum and provides a standard REST interface. It includes JWT authentication, Prometheus metrics, CORS configuration, and optional TLS."},"1132":{"id":"/docs/server/networking-43","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#http","content":"HTTP is the most accessible protocol but has the highest overhead due to JSON serialization and the stateless nature of HTTP (no persistent connections for consumer groups). You can find all the available endpoints in the server.http file."},"1133":{"id":"/docs/server/networking-44","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#http","content":"The HTTP server also hosts:"},"1134":{"id":"/docs/server/networking-45","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#http","content":"Prometheus metrics at /metrics (configurable endpoint)"},"1135":{"id":"/docs/server/networking-46","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#http","content":"Embedded Web UI at /ui (when compiled with iggy-web feature)"},"1136":{"id":"/docs/server/networking-47","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#websocket","content":"WebSocket provides bidirectional streaming over HTTP upgrade. Iggy uses a custom compio-ws implementation that bridges the gap between tungstenite's poll-based model and compio's completion-based model."},"1137":{"id":"/docs/server/networking-48","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#websocket","content":"The challenge was fundamental: traditional WebSocket libraries expect std::io::Read (caller owns the buffer), while compio's AsyncRead takes ownership of the buffer (kernel owns it temporarily). The solution is a GrowableSyncStream that dynamically grows from a 128 KB base, with linear growth in base capacity increments, a 64 MB cap, and auto-shrink when the buffer exceeds 4x the base and data is consumed."},"1138":{"id":"/docs/server/networking-49","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#websocket","content":"WebSocket runs on all shards (not just shard 0) and supports optional TLS."},"1139":{"id":"/docs/server/networking-50","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#websocket","content":"Benchmark comparison (AWS i3en.3xlarge, fsync per message, 4 producers, 40M messages):"},"1140":{"id":"/docs/server/networking-51","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#websocket","content":"Producer avg latency: TCP 2.61ms vs WebSocket 3.43ms (+31%)"},"1141":{"id":"/docs/server/networking-52","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#websocket","content":"Consumer avg latency: TCP 0.70ms vs WebSocket 1.44ms (+106%)"},"1142":{"id":"/docs/server/networking-53","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"All transport protocols support TLS encryption:"},"1143":{"id":"/docs/server/networking-54","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"Transport"},"1144":{"id":"/docs/server/networking-55","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"TLS Mechanism"},"1145":{"id":"/docs/server/networking-56","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"TCP"},"1146":{"id":"/docs/server/networking-57","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"Optional, via rustls"},"1147":{"id":"/docs/server/networking-58","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"QUIC"},"1148":{"id":"/docs/server/networking-59","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"Built-in, mandatory (part of QUIC spec)"},"1149":{"id":"/docs/server/networking-60","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"HTTP"},"1150":{"id":"/docs/server/networking-61","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"Optional HTTPS"},"1151":{"id":"/docs/server/networking-62","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"WebSocket"},"1152":{"id":"/docs/server/networking-63","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"Inherits from its transport"},"1153":{"id":"/docs/server/networking-64","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#tls","content":"All protocols support self-signed certificate generation when self_signed = true and the cert files don't exist. For production, provide proper certificate files via the cert_file and key_file settings."},"1154":{"id":"/docs/server/networking-65","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#heartbeat","content":"An optional heartbeat mechanism can verify client liveness:"},"1155":{"id":"/docs/server/networking-66","page_id":"/docs/server/networking","tags":[],"type":"text","url":"/docs/server/networking#heartbeat","content":"When enabled, the server expects periodic heartbeat messages from connected clients. Clients that miss heartbeats may be disconnected."},"1156":{"id":"/docs/server/schema","page_id":"/docs/server/schema","type":"page","content":"Schema","breadcrumbs":["Documentation","Server"],"tags":[],"url":"/docs/server/schema"},"1157":{"id":"/docs/server/schema-0","page_id":"/docs/server/schema","type":"heading","tags":[],"url":"/docs/server/schema#request-schema","content":"Request schema"},"1158":{"id":"/docs/server/schema-1","page_id":"/docs/server/schema","type":"heading","tags":[],"url":"/docs/server/schema#response-schema","content":"Response schema"},"1159":{"id":"/docs/server/schema-2","page_id":"/docs/server/schema","type":"heading","tags":[],"url":"/docs/server/schema#request-codes","content":"Request codes"},"1160":{"id":"/docs/server/schema-3","page_id":"/docs/server/schema","type":"heading","tags":[],"url":"/docs/server/schema#shared","content":"Shared"},"1161":{"id":"/docs/server/schema-4","page_id":"/docs/server/schema","type":"heading","tag