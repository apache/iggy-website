sinks/elasticsearch","tags":[],"type":"text","url":"/docs/connectors/sinks/elasticsearch#features","content":"Automatic index creation"},"1633":{"id":"/docs/connectors/sinks/elasticsearch-12","page_id":"/docs/connectors/sinks/elasticsearch","tags":[],"type":"text","url":"/docs/connectors/sinks/elasticsearch#features","content":"Error handling and retry mechanisms"},"1634":{"id":"/docs/connectors/sinks/elasticsearch-13","page_id":"/docs/connectors/sinks/elasticsearch","tags":[],"type":"text","url":"/docs/connectors/sinks/elasticsearch#features","content":"Metadata field injection"},"1635":{"id":"/docs/connectors/sinks/elasticsearch-14","page_id":"/docs/connectors/sinks/elasticsearch","tags":[],"type":"text","url":"/docs/connectors/sinks/elasticsearch#features","content":"Support for multiple data formats"},"1636":{"id":"/docs/connectors/sinks/iceberg","page_id":"/docs/connectors/sinks/iceberg","type":"page","content":"Iceberg Sink","breadcrumbs":["Documentation","Connectors","Sinks"],"tags":[],"url":"/docs/connectors/sinks/iceberg"},"1637":{"id":"/docs/connectors/sinks/iceberg-0","page_id":"/docs/connectors/sinks/iceberg","type":"heading","tags":[],"url":"/docs/connectors/sinks/iceberg#features","content":"Features"},"1638":{"id":"/docs/connectors/sinks/iceberg-1","page_id":"/docs/connectors/sinks/iceberg","type":"heading","tags":[],"url":"/docs/connectors/sinks/iceberg#configuration-example","content":"Configuration example"},"1639":{"id":"/docs/connectors/sinks/iceberg-2","page_id":"/docs/connectors/sinks/iceberg","type":"heading","tags":[],"url":"/docs/connectors/sinks/iceberg#configuration-options","content":"Configuration Options"},"1640":{"id":"/docs/connectors/sinks/iceberg-3","page_id":"/docs/connectors/sinks/iceberg","type":"heading","tags":[],"url":"/docs/connectors/sinks/iceberg#dynamic-routing","content":"Dynamic Routing"},"1641":{"id":"/docs/connectors/sinks/iceberg-4","page_id":"/docs/connectors/sinks/iceberg","type":"heading","tags":[],"url":"/docs/connectors/sinks/iceberg#dynamic-routing-configuration-example","content":"Dynamic routing configuration example"},"1642":{"id":"/docs/connectors/sinks/iceberg-5","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg","content":"The Iceberg Sink Connector allows you to consume messages from Iggy topics and store them in Iceberg tables."},"1643":{"id":"/docs/connectors/sinks/iceberg-6","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg#features","content":"Support for S3-compatible storage"},"1644":{"id":"/docs/connectors/sinks/iceberg-7","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg#features","content":"Support for REST catalogs"},"1645":{"id":"/docs/connectors/sinks/iceberg-8","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg#features","content":"Single destination table"},"1646":{"id":"/docs/connectors/sinks/iceberg-9","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg#features","content":"Multiple-table fan-out static routing"},"1647":{"id":"/docs/connectors/sinks/iceberg-10","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg#features","content":"Multiple-table fan-out dynamic routing"},"1648":{"id":"/docs/connectors/sinks/iceberg-11","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg#configuration-options","content":"tables: The names of the Iceberg tables you want to statically route Iggy messages to. The name should include the table’s namespace, separated by a dot (.)."},"1649":{"id":"/docs/connectors/sinks/iceberg-12","page_id":"/docs/connectors/sinks/iceberg","tags":[],"type":"text","url":"/docs/connectors/sinks/iceberg#configuration-options","content":"catalog_type: The type of catalog