ation","content":"Clustering is configured in the [cluster] section of config.toml:"},"365":{"id":"/docs/clustering/vsr-147","page_id":"/docs/clustering/vsr","tags":[],"type":"text","url":"/docs/clustering/vsr#cluster-configuration","content":"All nodes in the same cluster must share the same name to prevent accidental cross-cluster communication. Each node's ports field is optional and defaults to the current node's configured ports."},"366":{"id":"/docs/clustering/vsr-148","page_id":"/docs/clustering/vsr","tags":[],"type":"text","url":"/docs/clustering/vsr#current-status","content":"The VSR implementation includes the core consensus protocol, view change mechanism, deterministic timeout management, quorum tracking, shard-level plane multiplexing, and a network simulator for testing. Clustering is not yet production-ready but the foundational building blocks are in place and being actively developed. The server can be started as a follower node using the --follower flag."},"367":{"id":"/docs/connectors/introduction","page_id":"/docs/connectors/introduction","type":"page","content":"Introduction","breadcrumbs":["Documentation","Connectors"],"tags":[],"url":"/docs/connectors/introduction"},"368":{"id":"/docs/connectors/introduction-0","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#architecture","content":"Architecture"},"369":{"id":"/docs/connectors/introduction-1","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#data-flow","content":"Data Flow"},"370":{"id":"/docs/connectors/introduction-2","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#available-connectors","content":"Available Connectors"},"371":{"id":"/docs/connectors/introduction-3","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#transforms","content":"Transforms"},"372":{"id":"/docs/connectors/introduction-4","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#supported-schemas","content":"Supported Schemas"},"373":{"id":"/docs/connectors/introduction-5","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#features","content":"Features"},"374":{"id":"/docs/connectors/introduction-6","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#quick-start","content":"Quick Start"},"375":{"id":"/docs/connectors/introduction-7","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#configuration","content":"Configuration"},"376":{"id":"/docs/connectors/introduction-8","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#runtime","content":"Runtime"},"377":{"id":"/docs/connectors/introduction-9","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#sink","content":"Sink"},"378":{"id":"/docs/connectors/introduction-10","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#source","content":"Source"},"379":{"id":"/docs/connectors/introduction-11","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#building-the-connectors","content":"Building the connectors"},"380":{"id":"/docs/connectors/introduction-12","page_id":"/docs/connectors/introduction","type":"heading","tags":[],"url":"/docs/connectors/introduction#transformations","content":"Transformations"},"381":{"id":"/docs/connectors/introduction-13","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction","content":"The highly performant and modular runtime for statically typed, yet dynamically loaded connectors. Ingest the data from the external sources and push it further to the Iggy streams, or fetch the data from the Iggy streams and push it further to the external sources. Create your own Rust plugins by simply implementing either the Source or Sink trait and build custom pipelines for the data processing."},"382":{"id":"/docs/connectors/introduction-14","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction","content":"The docker image is available, and can be fetched via docker pull apache/iggy-connect."},"383":{"id":"/docs/connectors/introduction-15","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#architecture","content":"Connectors are dynamically loaded shared libraries (.so on Linux, .dylib on macOS, .dll on Windows) loaded at runtime via dlopen2. Data crossing the FFI boundary between the runtime and plugins is serialized using postcard, a compact binary format. Each plugin receives its own Tokio runtime inside the SDK, ensuring isolation."},"384":{"id":"/docs/connectors/introduction-16","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#data-flow","content":"The connector runtime operates in two directions - source (ingest) and sink (egress):"},"385":{"id":"/docs/connectors/introduction-17","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#data-flow","content":"Key details:"},"386":{"id":"/docs/connectors/introduction-18","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#data-flow","content":"Transforms run inside the runtime process, not inside the plugins. They are applied after decoding for sources (before sending to Iggy) and after consuming from Iggy for sinks (before forwarding to the external system)."},"387":{"id":"/docs/connectors/introduction-19","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#data-flow","content":"State persistence is file-based (using MessagePack serialization) and applies to source connectors only, tracking the last polled position."},"388":{"id":"/docs/connectors/introduction-20","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#data-flow","content":"Consumer groups handle offset tracking for sink connectors automatically, so sinks do not need to manage their own offsets."},"389":{"id":"/docs/connectors/introduction-21","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#available-connectors","content":"Type"},"390":{"id":"/docs/connectors/introduction-22","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#available-connectors","content":"Connectors"},"391":{"id":"/docs/connectors/introduction-23","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#available-connectors","content":"Source"},"392":{"id":"/docs/connectors/introduction-24","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#available-connectors","content":"PostgreSQL, Elasticsearch, Random"},"393":{"id":"/docs/connectors/introduction-25","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#available-connectors","content":"Sink"},"394":{"id":"/docs/connectors/introduction-26","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#available-connectors","content":"PostgreSQL, MongoDB, Elasticsearch, Quickwit, Apache Iceberg, Stdout"},"395":{"id":"/docs/connectors/introduction-27","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#transforms","content":"The following built-in transforms are available:"},"396":{"id":"/docs/connectors/introduction-28","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#transforms","content":"add_fields - add new fields to the message payload."},"397":{"id":"/docs/connectors/introduction-29","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#transforms","content":"delete_fields - remove existing fields from the message payload."},"398":{"id":"/docs/connectors/introduction-30","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#transforms","content":"filter_fields - keep only the specified fields, removing everything else."},"399":{"id":"/docs/connectors/introduction-31","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#transforms","content":"update_fields - update existing fields with computed values such as timestamp_millis or uuid_v7."},"400":{"id":"/docs/connectors/introduction-32","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#supported-schemas","content":"Messages can be decoded and encoded using the following formats: JSON, Raw bytes, Text, Protocol Buffers, and FlatBuffers."},"401":{"id":"/docs/connectors/introduction-33","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"High Performance: Utilizes Rust's performance characteristics to ensure fast data ingestion and egress."},"402":{"id":"/docs/connectors/introduction-34","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Low memory footprint: Designed with memory efficiency in mind, minimizing the memory footprint of the connectors."},"403":{"id":"/docs/connectors/introduction-35","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Modular Design: Designed with modularity in mind, allowing for easy extension and customization."},"404":{"id":"/docs/connectors/introduction-36","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Dynamic Loading: Supports dynamic loading of plugins, allowing integration with various data sources and sinks at runtime."},"405":{"id":"/docs/connectors/introduction-37","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Statically Typed: Ensures type safety and compile-time checks, reducing runtime errors."},"406":{"id":"/docs/connectors/introduction-38","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Easy Customization: Provides a simple interface for implementing custom connectors, making it easy to create new plugins."},"407":{"id":"/docs/connectors/introduction-39","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Data transformation: Supports data transformation with the help of existing functions."},"408":{"id":"/docs/connectors/introduction-40","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Powerful configuration: Define your sinks, sources, and transformations in the configuration file or fetch them from a remote HTTP API."},"409":{"id":"/docs/connectors/introduction-41","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#features","content":"Flexible configuration providers: Support for local file-based and HTTP-based configuration providers for centralized configuration management."},"410":{"id":"/docs/connectors/introduction-42","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#quick-start","content":"Build the project in release mode (or debug, and update the connectors paths in the config accordingly), and make sure that the plugins specified in core/connectors/runtime/example_config/connectors/ directory under path are available. The configuration must be provided in toml format."},"411":{"id":"/docs/connectors/introduction-43","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#quick-start","content":"Run docker compose up -d from /examples/rust/src/sink-data-producer which will start the Quickwit server to be used by an example sink connector. At this point, you can access the Quickwit UI at http://localhost:7280 - check this dashboard again later on, after the events index will be created."},"412":{"id":"/docs/connectors/introduction-44","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#quick-start","content":"Set environment variable IGGY_CONNECTORS_CONFIG_PATH=core/connectors/runtime/example_config/config.toml (adjust the path as needed) pointing to the runtime configuration file."},"413":{"id":"/docs/connectors/introduction-45","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#quick-start","content":"Start the Iggy server and invoke the following commands via Iggy CLI to create the example streams and topics used by the sample connectors."},"414":{"id":"/docs/connectors/introduction-46","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#quick-start","content":"Execute cargo run --example sink-data-producer -r which will start the example data producer application, sending the messages to previously created qw stream and records topic (this will be used by the Quickwit sink connector)."},"415":{"id":"/docs/connectors/introduction-47","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#quick-start","content":"Start the connector runtime cargo run --bin iggy-connectors -r - you should be able to browse Quickwit UI with records being constantly added to the events index. At the same time, you should see the new messages being added to the example stream and topic1 topic by the test source connector - you can use Iggy Web UI to browse the data. The messages will have applied the basic fields transformations."},"416":{"id":"/docs/connectors/introduction-48","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#configuration","content":"The same rules applies when it comes to overringing the configuration via environment variables as for the main Iggy server."},"417":{"id":"/docs/connectors/introduction-49","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#configuration","content":"You can provide the following envs during the runtime startup:"},"418":{"id":"/docs/connectors/introduction-50","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#configuration","content":"Any configuration section can be overriden with IGGY_CONNECTORS_ prefix, followed by the section name and the key name, e.g. IGGY_CONNECTORS_IGGY_USERNAME."},"419":{"id":"/docs/connectors/introduction-51","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#runtime","content":"All the connectors are implemented as Rust libraries and can be used as a part of the connector runtime. The runtime is responsible for managing the lifecycle of the connectors and providing the necessary infrastructure for the connectors to run. For more information, please refer to the runtime documentation."},"420":{"id":"/docs/connectors/introduction-52","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#sink","content":"Sinks are responsible for consuming the messages from the configured stream(s) and topic(s) and sending them further to the specified destination. For example, the Quickwit sink connector is responsible for sending the messages to the Quickwit indexer."},"421":{"id":"/docs/connectors/introduction-53","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#sink","content":"Please refer to the Sink documentation for the details about the configuration and the sample implementation."},"422":{"id":"/docs/connectors/introduction-54","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#sink","content":"When implementing Sink, make sure to use the sink_connector! macro to expose the FFI interface and allow the connector runtime to register the sink with the runtime.\nEach sink should have its own, custom configuration, which is passed along with the unique plugin ID via expected new() method."},"423":{"id":"/docs/connectors/introduction-55","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#source","content":"Sources are responsible for producing the messages to the configured stream(s) and topic(s). For example, the Test source connector will generate the random messages that will be then sent to the configured stream and topic."},"424":{"id":"/docs/connectors/introduction-56","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#source","content":"Please refer to the Source documentation for the details about the configuration and the sample implementation."},"425":{"id":"/docs/connectors/introduction-57","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#building-the-connectors","content":"New connector can be built simply by implementing either Sink or Source trait. Please check the sink or source documentation, as well as the existing examples under /sinks and /sources directories."},"426":{"id":"/docs/connectors/introduction-58","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#transformations","content":"Field transformations (depending on the supported payload formats) can be applied to the messages either before they are sent to the specified topic (e.g. when produced by the source connectors), or before consumed by the sink connectors. To add the new transformation, simply implement the Transform trait and extend the existing load function. Each transform may have its own, custom configuration."},"427":{"id":"/docs/connectors/introduction-59","page_id":"/docs/connectors/introduction","tags":[],"type":"text","url":"/docs/connectors/introduction#transformations","content":"To find out more about the transforms, stream decoders or encoders, please refer to the SDK documentation."},"428":{"id":"/docs/connectors/runtime","page_id":"/docs/connectors/runtime","type":"page","content":"Runtime","breadcrumbs":["Documentation","Connectors"],"tags":[],"url":"/docs/connectors/runtime"},"429":{"id":"/docs/connectors/runtime-0","page_id":"/docs/connectors/runtime","type":"heading","tags":[],"url":"/docs/connectors/runtime#configuration-providers","content":"Configuration Providers"},"430":{"id":"/docs/connectors/runtime-1","page_id":"/docs/connectors/runtime","type":"heading","tags":[],"url":"/docs/connectors/runtime#local-file-provider","content":"Local File Provider"},"431":{"id":"/docs/connectors/runtime-2","page_id":"/docs/connectors/runtime","type":"heading","tags":[],"url":"/docs/connectors/runtime#http-configuration-provider","content":"HTTP Configuration Provider"},"432":{"id":"/docs/connectors/runtime-3","page_id":"/docs/connectors/runtime","type":"heading","tags":[],"url":"/docs/connectors/runtime#configuration-options","content":"Configuration Options"},"433":{"id":"/docs/connectors/runtime-4","page_id":"/docs/connectors/runtime","type":"heading","tags":[],"url":"/docs/connectors/runtime#default-url-templates","content":"Default URL Templates"},"434":{"id":"/docs/connectors/runtime-5","page_id":"/docs/connectors/runtime","type":"heading","tags":[],"url":"/docs/connectors/runtime#http-api","content":"HTTP API"},"435":{"id":"/docs/connectors/runtime-6","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"Runtime is responsible for managing the lifecycle of the connectors and providing the necessary infrastructure for the connectors to run."},"436":{"id":"/docs/connectors/runtime-7","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"The runtime uses a shared Tokio runtime to manage the asynchronous tasks and events across all connectors. Additionally, it has built-in support for logging via tracing crate."},"437":{"id":"/docs/connectors/runtime-8","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"The connector are implemented as Rust libraries, and these are loaded dynamically during the runtime initialization process."},"438":{"id":"/docs/connectors/runtime-9","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"Internally, dlopen2 provides a safe and efficient way of loading the plugins via C FFI."},"439":{"id":"/docs/connectors/runtime-10","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"By default, runtime will look for the configuration file, to decide which connectors to load and how to configure them."},"440":{"id":"/docs/connectors/runtime-11","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"To start the connector runtime, simply run cargo run --bin iggy-connectors."},"441":{"id":"/docs/connectors/runtime-12","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"The docker image is available, and can be fetched via docker pull apache/iggy-connect."},"442":{"id":"/docs/connectors/runtime-13","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"The minimal viable configuration requires at least the Iggy credentials to create 2 separate instances of producer & consumer connections, the state directory path where source connectors can store their optional state, and the connectors configuration provider settings."},"443":{"id":"/docs/connectors/runtime-14","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime","content":"The path to the configuration can be overridden by IGGY_CONNECTORS_CONFIG_PATH environment variable. Each configuration section can be also additionally updated by using the following convention IGGY_CONNECTORS_SECTION_NAME.KEY_NAME e.g. IGGY_CONNECTORS_IGGY_USERNAME and so on."},"444":{"id":"/docs/connectors/runtime-15","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#configuration-providers","content":"The runtime supports two types of configuration providers for managing connector configurations:"},"445":{"id":"/docs/connectors/runtime-16","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#local-file-provider","content":"The default configuration provider reads connector configurations from local files. Each connector (source or sink) is configured in its own separate file within the directory specified by connectors.config_dir. If config_dir is empty or the directory doesn't exist, no connectors will be loaded."},"446":{"id":"/docs/connectors/runtime-17","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#http-configuration-provider","content":"The HTTP configuration provider allows the runtime to fetch connector configurations from a remote HTTP/REST API. This enables centralized configuration management and dynamic configuration updates."},"447":{"id":"/docs/connectors/runtime-18","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#configuration-options","content":"base_url (required): Base URL of the configuration API endpoint"},"448":{"id":"/docs/connectors/runtime-19","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#configuration-options","content":"timeout (optional): HTTP request timeout (default: 10s)"},"449":{"id":"/docs/connectors/runtime-20","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#configuration-options","content":"request_headers (optional): Custom headers to include in all HTTP requests (e.g., authentication headers)"},"450":{"id":"/docs/connectors/runtime-21","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#configuration-options","content":"url_templates (optional): Custom URL templates for API endpoints. Supports variable substitution with {key} and {version} placeholders."},"451":{"id":"/docs/connectors/runtime-22","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#configuration-options","content":"response.data_path (optional): JSON path to extract response data from nested structures (e.g., \"data.config\")"},"452":{"id":"/docs/connectors/runtime-23","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#configuration-options","content":"response.error_path (optional): JSON path to check for errors in responses"},"453":{"id":"/docs/connectors/runtime-24","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#default-url-templates","content":"If not customized, the HTTP provider uses the following RESTful URL patterns:"},"454":{"id":"/docs/connectors/runtime-25","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#default-url-tem