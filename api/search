":{"id":"/docs/server/security-3","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#authorization","content":"Authorization"},"1146":{"id":"/docs/server/security-4","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#permission-hierarchy","content":"Permission hierarchy"},"1147":{"id":"/docs/server/security-5","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#global-permissions","content":"Global permissions"},"1148":{"id":"/docs/server/security-6","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#stream-permissions","content":"Stream permissions"},"1149":{"id":"/docs/server/security-7","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#topic-permissions","content":"Topic permissions"},"1150":{"id":"/docs/server/security-8","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#how-permissions-cascade","content":"How permissions cascade"},"1151":{"id":"/docs/server/security-9","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#example-read-only-user-for-a-specific-stream","content":"Example: read-only user for a specific stream"},"1152":{"id":"/docs/server/security-10","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#transport-encryption-tls","content":"Transport encryption (TLS)"},"1153":{"id":"/docs/server/security-11","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#data-encryption-at-rest","content":"Data encryption at rest"},"1154":{"id":"/docs/server/security-12","page_id":"/docs/server/security","type":"heading","tags":[],"url":"/docs/server/security#jwt-http-api","content":"JWT (HTTP API)"},"1155":{"id":"/docs/server/security-13","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security","content":"Iggy provides multiple layers of security covering authentication, authorization, transport encryption, and data encryption at rest."},"1156":{"id":"/docs/server/security-14","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#authentication","content":"Iggy supports two authentication mechanisms:"},"1157":{"id":"/docs/server/security-15","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#username-and-password","content":"Users authenticate with a username and password via login_user(). Passwords are hashed using Argon2id (a memory-hard hashing algorithm). On first startup, the server generates a random password for the root user and logs it to the console. You can override this by setting environment variables:"},"1158":{"id":"/docs/server/security-16","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#username-and-password","content":"Or use the --with-default-root-credentials flag for development (sets root credentials to iggy/iggy)."},"1159":{"id":"/docs/server/security-17","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#username-and-password","content":"Important: once the data directory exists, environment variable credentials are ignored. To reset credentials, you must use the --fresh flag (which deletes all data)."},"1160":{"id":"/docs/server/security-18","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#personal-access-tokens-pat","content":"PATs provide programmatic access with optional expiry. Each user can have up to max_tokens_per_user (default 100) active tokens. Tokens are hashed before storage and can be revoked at any time."},"1161":{"id":"/docs/server/security-19","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#personal-access-tokens-pat","content":"An automatic cleaner removes expired tokens at a configurable interval."},"1162":{"id":"/docs/server/security-20","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#authorization","content":"Iggy provides granular permissions at three levels:"},"1163":{"id":"/docs/server/security-21","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#authorization","content":"Global permissions - system-wide operations (manage servers, manage users, read servers)"},"1164":{"id":"/docs/server/security-22","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#authorization","content":"Stream permissions - per-stream operations (manage stream, read stream, manage topics, read topics, poll messages, send messages)"},"1165":{"id":"/docs/server/security-23","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#authorization","content":"Topic permissions - per-topic operations within a stream (manage topic, read topic, poll messages, send messages)"},"1166":{"id":"/docs/server/security-24","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#authorization","content":"The root user has full access to everything and bypasses all permission checks. Other users can be assigned specific permissions using the CLI, SDK, or Web UI."},"1167":{"id":"/docs/server/security-25","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#permission-hierarchy","content":"Permissions are organized in a tree structure. At the top level, the Permissions struct holds both global and per-stream settings:"},"1168":{"id":"/docs/server/security-26","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#permission-hierarchy","content":"The global field controls system-wide operations, while streams is an optional map keyed by stream ID that lets you grant fine-grained access to individual streams."},"1169":{"id":"/docs/server/security-27","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#global-permissions","content":"GlobalPermissions contains boolean fields that govern server-wide operations:"},"1170":{"id":"/docs/server/security-28","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#global-permissions","content":"Note that \"manage\" permissions are always supersets of their \"read\" counterparts. For example, if manage_streams is true, the user can also read streams, even if read_streams is false. Similarly, read_topics is a superset of poll_messages, so granting read_topics implicitly allows polling messages too."},"1171":{"id":"/docs/server/security-29","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#stream-permissions","content":"When you need to restrict a user to specific streams rather than granting global access, use StreamPermissions:"},"1172":{"id":"/docs/server/security-30","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#stream-permissions","content":"The topics field works just like the streams field one level up. It is an optional map keyed by topic ID that lets you drill down even further."},"1173":{"id":"/docs/server/security-31","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#topic-permissions","content":"At the most granular level, TopicPermissions controls access to a single topic within a stream:"},"1174":{"id":"/docs/server/security-32","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#how-permissions-cascade","content":"Permissions are checked from top to bottom: global, then stream, then topic. If a permission is granted at a higher level, it covers everything below it. For instance:"},"1175":{"id":"/docs/server/security-33","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#how-permissions-cascade","content":"Setting global.poll_messages = true lets the user poll messages from all streams and topics."},"1176":{"id":"/docs/server/security-34","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#how-permissions-cascade","content":"Setting stream[1].poll_messages = true lets the user poll messages from all topics in stream 1, but not from other streams."},"1177":{"id":"/docs/server/security-35","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#how-permissions-cascade","content":"Setting stream[1].topics[5].poll_messages = true lets the user poll messages only from topic 5 in stream 1."},"1178":{"id":"/docs/server/security-36","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#how-permissions-cascade","content":"If the streams map is None (or a specific stream ID is absent from it), the user has no stream-level overrides and only global permissions apply. The same logic holds for the topics map within a stream."},"1179":{"id":"/docs/server/security-37","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#example-read-only-user-for-a-specific-stream","content":"Suppose you want to create a user that can only poll messages from stream 42, with no other access. You would set up their permissions like this:"},"1180":{"id":"/docs/server/security-38","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#example-read-only-user-for-a-specific-stream","content":"This user can read stream 42, list its topics, and poll messages from any topic within it, but cannot send messages, create topics, or access any other stream."},"1181":{"id":"/docs/server/security-39","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#transport-encryption-tls","content":"All transport protocols support TLS encryption:"},"1182":{"id":"/docs/server/security-40","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#transport-encryption-tls","content":"TCP: Optional TLS via rustls. Enable with tcp.tls.enabled = true."},"1183":{"id":"/docs/server/security-41","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#transport-encryption-tls","content":"QUIC: TLS is mandatory (built into the QUIC protocol). Uses self-signed certificates by default."},"1184":{"id":"/docs/server/security-42","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#transport-encryption-tls","content":"HTTP: Optional HTTPS. Enable with http.tls.enabled = true."},"1185":{"id":"/docs/server/security-43","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#transport-encryption-tls","content":"WebSocket: Optional TLS. Enable with websocket.tls.enabled = true."},"1186":{"id":"/docs/server/security-44","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#transport-encryption-tls","content":"All protocols support automatic self-signed certificate generation when self_signed = true and the certificate files don't exist. For production deployments, provide proper certificates via cert_file and key_file."},"1187":{"id":"/docs/server/security-45","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#data-encryption-at-rest","content":"Iggy supports optional AES-256-GCM encryption for message payloads and state commands. When enabled, all data is encrypted before being written to disk and decrypted when read. The encryption key must be a 32-byte base64-encoded string."},"1188":{"id":"/docs/server/security-46","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#jwt-http-api","content":"The HTTP API uses JWT (JSON Web Tokens) for session management. Tokens are signed with HS256 by default and have configurable expiry, clock skew tolerance, and audience/issuer validation."},"1189":{"id":"/docs/server/security-47","page_id":"/docs/server/security","tags":[],"type":"text","url":"/docs/server/security#jwt-http-api","content":"Important: change the default encoding_secret and decoding_secret values in production."},"1190":{"id":"/docs/server/storage-engine","page_id":"/docs/server/storage-engine","type":"page","content":"Storage Engine","breadcrumbs":["Documentation","Server"],"tags":[],"url":"/docs/server/storage-engine"},"1191":{"id":"/docs/server/storage-engine-0","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#directory-layout","content":"Directory layout"},"1192":{"id":"/docs/server/storage-engine-1","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#segmented-log","content":"Segmented log"},"1193":{"id":"/docs/server/storage-engine-2","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#message-binary-format","content":"Message binary format"},"1194":{"id":"/docs/server/storage-engine-3","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#indexes","content":"Indexes"},"1195":{"id":"/docs/server/storage-engine-4","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#write-pipeline","content":"Write pipeline"},"1196":{"id":"/docs/server/storage-engine-5","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#memory-pool","content":"Memory pool"},"1197":{"id":"/docs/server/storage-engine-6","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#zero-copy-deserialization","content":"Zero-copy deserialization"},"1198":{"id":"/docs/server/storage-engine-7","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#retention-and-cleanup","content":"Retention and cleanup"},"1199":{"id":"/docs/server/storage-engine-8","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#message-deduplication","content":"Message deduplication"},"1200":{"id":"/docs/server/storage-engine-9","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#encryption","content":"Encryption"},"1201":{"id":"/docs/server/storage-engine-10","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#compression","content":"Compression"},"1202":{"id":"/docs/server/storage-engine-11","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#backup-and-archiving","content":"Backup and archiving"},"1203":{"id":"/docs/server/storage-engine-12","page_id":"/docs/server/storage-engine","type":"heading","tags":[],"url":"/docs/server/storage-engine#state-persistence-write-ahead-log","content":"State persistence (Write-ahead log)"},"1204":{"id":"/docs/server/storage-engine-13","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine","content":"Iggy's storage engine is built around the concept of a segmented append-only log. Every piece of data flows through a well-defined hierarchy: System -> Streams -> Topics -> Partitions -> Segments. This page covers how data is stored, indexed, flushed, and managed on disk."},"1205":{"id":"/docs/server/storage-engine-14","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#directory-layout","content":"All data is stored under the system.path directory (default local_data):"},"1206":{"id":"/docs/server/storage-engine-15","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#directory-layout","content":"Each partition directory contains pairs of .log and .index files. The filename is the start offset of the first message in that segment, zero-padded to 20 digits."},"1207":{"id":"/docs/server/storage-engine-16","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#segmented-log","content":"The SegmentedLog is the core storage abstraction per partition. It contains an ordered list of sealed (read-only) segments plus one active (writable) segment. When the active segment reaches its configured size limit (default 1 GiB), it is sealed and a new active segment is created."},"1208":{"id":"/docs/server/storage-engine-17","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#segmented-log","content":"Key segment tracking fields:"},"1209":{"id":"/docs/server/storage-engine-18","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#segmented-log","content":"start_offset / end_offset - first and last message position"},"1210":{"id":"/docs/server/storage-engine-19","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#segmented-log","content":"current_position - write pointer in bytes"},"1211":{"id":"/docs/server/storage-engine-20","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#segmented-log","content":"size - configured maximum (must be a multiple of 512 bytes)"},"1212":{"id":"/docs/server/storage-engine-21","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#segmented-log","content":"sealed - whether the segment accepts new writes"},"1213":{"id":"/docs/server/storage-engine-22","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-engine#message-binary-format","content":"Each message on disk consists of a 64-byte header followed by optional user headers and the payload:"},"1214":{"id":"/docs/server/storage-engine-23","page_id":"/docs/server/storage-engine","tags":[],"type":"text","url":"/docs/server/storage-