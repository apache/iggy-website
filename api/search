/runtime-61","page_id":"/docs/connectors/runtime","tags":[],"type":"text","url":"/docs/connectors/runtime#http-api","content":"GET /sources/{key}/transforms: source transforms to be applied to the fields."},"491":{"id":"/docs/connectors/sdk","page_id":"/docs/connectors/sdk","type":"page","content":"SDK","breadcrumbs":["Documentation","Connectors"],"tags":[],"url":"/docs/connectors/sdk"},"492":{"id":"/docs/connectors/sdk-0","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#protocol-buffers-support","content":"Protocol Buffers Support"},"493":{"id":"/docs/connectors/sdk-1","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#configuration-example","content":"Configuration Example"},"494":{"id":"/docs/connectors/sdk-2","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#key-configuration-options","content":"Key Configuration Options"},"495":{"id":"/docs/connectors/sdk-3","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#source-configuration","content":"Source Configuration"},"496":{"id":"/docs/connectors/sdk-4","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#transform-options","content":"Transform Options"},"497":{"id":"/docs/connectors/sdk-5","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#supported-features","content":"Supported Features"},"498":{"id":"/docs/connectors/sdk-6","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#programmatic-usage","content":"Programmatic Usage"},"499":{"id":"/docs/connectors/sdk-7","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#dynamic-schema-loading","content":"Dynamic Schema Loading"},"500":{"id":"/docs/connectors/sdk-8","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#schema-registry-integration","content":"Schema Registry Integration"},"501":{"id":"/docs/connectors/sdk-9","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#creating-converters-with-schema","content":"Creating Converters with Schema"},"502":{"id":"/docs/connectors/sdk-10","page_id":"/docs/connectors/sdk","type":"heading","tags":[],"url":"/docs/connectors/sdk#usage-notes","content":"Usage Notes"},"503":{"id":"/docs/connectors/sdk-11","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk","content":"SDK provides the commonly used structs and traits such as Sink and Source, along with the sink_connector and source_connector macros to be used when developing connectors."},"504":{"id":"/docs/connectors/sdk-12","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk","content":"Moreover, it contains both, the decoders and encoders modules, implementing either StreamDecoder or StreamEncoder traits, which are used when consuming or producing data from/to Iggy streams."},"505":{"id":"/docs/connectors/sdk-13","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk","content":"SDK is WiP, and it'd certainly benefit from having the support of multiple format schemas, such as Avro, Flatbuffers etc. including decoding/encoding the data between the different formats (when applicable) and supporting the data transformations whenever possible (easy for JSON, but complex for Bincode for example)."},"506":{"id":"/docs/connectors/sdk-14","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk","content":"Last but not least, the different transforms are available, to transform (add, update, delete etc.) the particular fields of the data being processed via external configuration. It's as simple as adding a new transform to the transforms section of the particular connector configuration file:"},"507":{"id":"/docs/connectors/sdk-15","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#protocol-buffers-support","content":"The SDK includes support for Protocol Buffers (protobuf) format with both encoding and decoding capabilities. Protocol Buffers provide efficient serialization and are particularly useful for high-performance data streaming scenarios."},"508":{"id":"/docs/connectors/sdk-16","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#configuration-example","content":"Here's a complete example configuration for using Protocol Buffers with Iggy connectors."},"509":{"id":"/docs/connectors/sdk-17","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#configuration-example","content":"Main runtime config (config.toml):"},"510":{"id":"/docs/connectors/sdk-18","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#configuration-example","content":"Source connector config (connectors/protobuf_source.toml):"},"511":{"id":"/docs/connectors/sdk-19","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#configuration-example","content":"Sink connector config (connectors/protobuf_sink.toml):"},"512":{"id":"/docs/connectors/sdk-20","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#source-configuration","content":"schema_path: Path to the .proto file containing message definitions"},"513":{"id":"/docs/connectors/sdk-21","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#source-configuration","content":"message_type: Fully qualified name of the protobuf message type to use"},"514":{"id":"/docs/connectors/sdk-22","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"/docs/connectors/sdk#source-configuration","content":"use_any_wrapper: Whether to wrap messages in google.protobuf.Any for type safety"},"515":{"id":"/docs/connectors/sdk-23","page_id":"/docs/connectors/sdk","tags":[],"type":"text","url":"